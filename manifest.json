{
  "manifest_version": 3,
  "name": "CadetNet Enhanced",
  "version": "1.0.0",
  "description": "Modern visual redesign and productivity tools for CadetNet (CEA)",
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://apps.cadetnet.gov.au/*",
        "https://*.cadetnet.gov.au/*"
      ],
      "css": [
        "css/variables.css",
        "css/base.css",
        "css/navigation.css",
        "css/forms.css",
        "css/tables.css",
        "css/components.css",
        "css/modals.css",
        "css/widgets.css",
        "css/pages.css",
        "css/utilities.css",
        "css/reporting.css"
      ],
      "js": [
        "js/settings.js",
        "js/utils.js",
        "js/dom-fixes.js",
        "js/modals.js",
        "js/quick-actions.js",
        "js/sidebar.js",
        "js/status-bar.js",
        "js/transitions.js",
        "js/icons.js",
        "js/admin-panel.js",
        "js/reporting.js",
        "js/init.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
